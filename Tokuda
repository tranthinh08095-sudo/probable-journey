-- ====== TOGGLE FUNCTIONS ======

function toggleFarm()
    state.farming = not state.farming
    if state.farming then
        if threads.farm then coroutine.close(threads.farm) end
        threads.farm = spawn(autoFarm)
    else
        if threads.farm then
            coroutine.close(threads.farm)
            threads.farm = nil
        end
        currentTarget = nil
    end
end

function toggleCollect()
    state.collecting = not state.collecting
    if state.collecting then
        if threads.collect then coroutine.close(threads.collect) end
        threads.collect = spawn(autoCollect)
    else
        if threads.collect then
            coroutine.close(threads.collect)
            threads.collect = nil
        end
    end
end

function toggleHaki()
    state.haki = not state.haki
    if state.haki then
        spawn(autoHaki)
    end
end

function toggleESP()
    state.esp = not state.esp
    spawn(esp)
end

function toggleAntiFall()
    state.antiFall = not state.antiFall
    if state.antiFall then
        spawn(antiFall)
    end
end

