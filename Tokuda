-- Button creator
function createToggleButton(text, posY, color, toggleFunc)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.85, 0, 0, 30)
    btn.Position = UDim2.new(0.075, 0, posY, 0)
    btn.Text = text
    btn.BackgroundColor3 = color
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.GothamMedium
    btn.TextSize = 12
    btn.Parent = mainFrame
    
    local stateVal = false
    btn.MouseButton1Click:Connect(function()
        toggleFunc()
        -- Find matching state
        if text:match("FARM") then stateVal = state.farming
        elseif text:match("COLLECT") then stateVal = state.collecting
        elseif text:match("HAKI") then stateVal = state.haki
        elseif text:match("ESP") then stateVal = state.esp
        elseif text:match("ANTI FALL") then stateVal = state.antiFall
        end
        
        if stateVal then
            btn.BackgroundColor3 = Color3.new(0, 0.8, 0)
            btn.Text = "▶ " .. text
        else
            btn.BackgroundColor3 = color
            btn.Text = text
        end
    end)
    return btn
end

