repeat wait(0.1) until game:IsLoaded()

-- ====== VARIABLES ======
local player = game.Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")
local rootPart = character:WaitForChild("HumanoidRootPart")
local vInput = game:GetService("VirtualInputManager")
local runService = game:GetService("RunService")

-- ====== SETTINGS ======
local settings = {
    FarmRadius = 400,
    AttackDelay = 0.08,
    CollectRadius = 200,
    FlyHeight = 8,
    UseSkills = true,
    AutoHaki = true,
    ESP = true,
    AntiFall = true,
}

-- ====== CONTROL VARIABLES ======
local state = {
    farming = false,
    collecting = false,
    haki = false,
    esp = false,
    antiFall = false,
}

local threads = {
    farm = nil,
    collect = nil,
}

local currentTarget = nil

-- ====== UTILITY ======

function teleport(pos)
    rootPart.CFrame = pos
    wait(0.05)
end

function isAlive(mob)
    return mob and mob:FindFirstChild("Humanoid") and mob.Humanoid.Health > 0
end

function getMobs()
    local enemies = workspace:FindFirstChild("Enemies") or workspace:FindFirstChild("Mobs")
    if not enemies then return {} end
    return enemies:GetChildren()
end

function getNearestMob()
    local nearest = nil
    local nearestDist = math.huge
    
    for _, mob in pairs(getMobs()) do
        if isAlive(mob) then
            local dist = (rootPart.Position - mob.HumanoidRootPart.Position).Magnitude
            if dist < settings.FarmRadius and dist < nearestDist then
                nearestDist = dist
                nearest = mob
            end
        end
    end
    return nearest
end

function getFruits()
    local fruits = workspace:FindFirstChild("Fruits")
    if not fruits then return {} end
    return fruits:GetChildren()
end

-- ====== CORE FUNCTIONS ======

function doAttack()
    vInput:SendMouseButtonEvent(0, 0, 0, true, game, 0)
    wait(0.03)
    vInput:SendMouseButtonEvent(0, 0, 0, false, game, 0)
    
    if settings.UseSkills then
        for _, key in ipairs({"1", "2", "3"}) do
            vInput:SendKeyEvent(true, key, false, game)
            wait(0.02)
            vInput:SendKeyEvent(false, key, false, game)
            wait(0.03)
        end
    end
end

function equipWeapon()
    local backpack = player:FindFirstChild("Backpack")
    if not backpack then return end
    
    local weapons = {}
    for _, item in pairs(backpack:GetChildren()) do
        if item:IsA("Tool") then
            table.insert(weapons, item)
        end
    end
    
    if #weapons > 0 then
        local weapon = weapons[1]
        if not character:FindFirstChild(weapon.Name) then
            weapon.Parent = character
            wait(0.1)
        end
        -- Press 1,2,3 to switch
        for i = 1, math.min(#weapons, 3) do
            vInput:SendKeyEvent(true, tostring(i), false, game)
            wait(0.05)
            vInput:SendKeyEvent(false, tostring(i), false, game)
        end
    end
end

-- ====== AUTO FARM ======

function autoFarm()
    print("🟢 Auto Farm STARTED")
    equipWeapon()
    
    while state.farming do
        wait(0.1)
        
        if currentTarget == nil or not isAlive(currentTarget) then
            currentTarget = getNearestMob()
            if currentTarget then
                local pos = currentTarget.HumanoidRootPart.CFrame
                teleport(CFrame.new(pos.X, pos.Y + settings.FlyHeight, pos.Z))
                wait(0.1)
            end
        end
        
        if currentTarget and isAlive(currentTarget) then
            local mobPos = currentTarget.HumanoidRootPart.Position
            local dist = (rootPart.Position - mobPos).Magnitude
            local heightDiff = rootPart.Position.Y - mobPos.Y
            
            if dist > 50 or heightDiff < 2 then
                local pos = currentTarget.HumanoidRootPart.CFrame
                teleport(CFrame.new(pos.X, pos.Y + settings.FlyHeight, pos.Z))
                wait(0.05)
            end
            
            for i = 1, 10 do
                if not state.farming then break end
                if not isAlive(currentTarget) then break end
                
                doAttack()
                wait(settings.AttackDelay)
            end
        else
            local mobs = getMobs()
            if #mobs > 0 then
                currentTarget = mobs[math.random(1, #mobs)]
                if isAlive(currentTarget) then
                    local pos = currentTarget.HumanoidRootPart.CFrame
                    teleport(CFrame.new(pos.X, pos.Y + settings.FlyHeight, pos.Z))
                    wait(0.2)
                end
            else
                wait(0.5)
            end
        end
    end
    
    print("🔴 Auto Farm STOPPED")
end

-- ====== AUTO COLLECT ======

function autoCollect()
    print("🟢 Auto Collect STARTED")
    
    while state.collecting do
        wait(0.3)
        
        for _, fruit in pairs(getFruits()) do
            if fruit:FindFirstChild("Handle") then
                local dist = (rootPart.Position - fruit.Handle.Position).Magnitude
                if dist < settings.CollectRadius then
                    teleport(fruit.Handle.CFrame * CFrame.new(0, 0, 2))
                    wait(0.1)
                    fireclickdetector(fruit.Handle.ClickDetector)
                    wait(0.2)
                end
            end
        end
        
        -- Check for fruits in workspace
        for _, fruit in pairs(workspace:GetDescendants()) do
            if fruit:IsA("Part") and fruit.Name:match("Fruit") then
                local dist = (rootPart.Position - fruit.Position).Magnitude
                if dist < settings.CollectRadius then
                    teleport(fruit.CFrame * CFrame.new(0, 0, 2))
                    wait(0.1)
                    if fruit.Parent and fruit.Parent:FindFirstChild("ClickDetector") then
                        fireclickdetector(fruit.Parent.ClickDetector)
                    end
                end
            end
        end
    end
    
    print("🔴 Auto Collect STOPPED")
end

-- ====== AUTO HAKI ======

function autoHaki()
    while state.haki do
        wait(2)
        if humanoid:FindFirstChild("Haki") then
            humanoid.Haki.Value = true
        end
        if humanoid:FindFirstChild("Ken") then
            humanoid.Ken.Value = true
        end
    end
end

-- ====== ESP ======

function esp()
    while state.esp do
        wait(0.5)
        for _, mob in pairs(getMobs()) do
            if isAlive(mob) and not mob:FindFirstChild("Highlight") then
                local hl = Instance.new("Highlight")
                hl.Parent = mob
                hl.FillColor = Color3.new(1, 0, 0)
                hl.FillTransparency = 0.4
                hl.OutlineColor = Color3.new(1, 1, 1)
            end
        end
        
        for _, fruit in pairs(getFruits()) do
            if fruit:FindFirstChild("Handle") and not fruit:FindFirstChild("Highlight") then
                local hl = Instance.new("Highlight")
                hl.Parent = fruit
                hl.FillColor = Color3.new(0, 1, 0)
                hl.FillTransparency = 0.3
            end
        end
    end
    
    -- Clean up ESP when turned off
    for _, mob in pairs(getMobs()) do
        if mob:FindFirstChild("Highlight") then
            mob.Highlight:Destroy()
        end
    end
    for _, fruit in pairs(getFruits()) do
        if fruit:FindFirstChild("Highlight") then
            fruit.Highlight:Destroy()
        end
    end
end

-- ====== ANTI FALL ======

function antiFall()
    while state.antiFall do
        wait(0.1)
        if rootPart.Position.Y < -50 then
            teleport(CFrame.new(0, 100, 0))
        end
    end
end

