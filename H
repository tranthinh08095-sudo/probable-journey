-- ====== UPDATE UI ======

function updateUI()
    -- Clear old content
    for _, child in pairs(scrollFrame:GetChildren()) do
        if child:IsA("TextButton") or child:IsA("TextLabel") or child:IsA("Frame") then
            child:Destroy()
        end
    end
    
    -- Update tab colors
    for tab, btn in pairs(tabBtns) do
        btn.BackgroundColor3 = (tab == currentTab) and Color3.new(0.2, 0.5, 0.8) or Color3.new(0.1, 0.1, 0.15)
    end
    
    -- Show content based on tab
    if currentTab == "Farming" then
        createFarmingTab()
    elseif currentTab == "Raid" then
        createRaidTab()
    elseif currentTab == "Teleport" then
        createTeleportTab()
    elseif currentTab == "Settings" then
        createSettingsTab()
    end
end

