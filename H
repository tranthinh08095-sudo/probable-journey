-- ====== TOGGLE FUNCTIONS ======

function toggleFarm()
    state.farming = not state.farming
    if state.farming then spawn(autoFarm) else currentTarget = nil end
end

function toggleCollect()
    state.collecting = not state.collecting
    if state.collecting then spawn(autoCollect) end
end

function toggleHaki()
    state.haki = not state.haki
    if state.haki then spawn(autoHaki) end
end

function toggleESP()
    state.esp = not state.esp
    spawn(esp)
end

function toggleAntiFall()
    state.antiFall = not state.antiFall
    if state.antiFall then spawn(antiFall) end
end

