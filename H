-- ====== SETTINGS ======
local settings = {
    FarmRadius = 400,
    AttackDelay = 0.08,
    CollectRadius = 200,
    FlyHeight = 8,
    UseSkills = true,
}

-- ====== STATE ======
local state = {
    farming = false,
    collecting = false,
    haki = false,
    esp = false,
    antiFall = false,
    autoRaid = false,
}

local currentTarget = nil
local currentTab = "Farming"
local searchQuery = ""

-- ====== UTILITY ======

function teleport(pos)
    rootPart.CFrame = pos
    wait(0.05)
end

function isAlive(mob)
    return mob and mob:FindFirstChild("Humanoid") and mob.Humanoid.Health > 0
end

function getMobs()
    local enemies = workspace:FindFirstChild("Enemies") or workspace:FindFirstChild("Mobs")
    if not enemies then return {} end
    return enemies:GetChildren()
end

function getNearestMob()
    local nearest = nil
    local nearestDist = math.huge
    for _, mob in pairs(getMobs()) do
        if isAlive(mob) then
            local dist = (rootPart.Position - mob.HumanoidRootPart.Position).Magnitude
            if dist < settings.FarmRadius and dist < nearestDist then
                nearestDist = dist
                nearest = mob
            end
        end
    end
    return nearest
end

function getFruits()
    local fruits = workspace:FindFirstChild("Fruits")
    if not fruits then return {} end
    return fruits:GetChildren()
end

-- ====== ATTACK FUNCTIONS ======

function doAttack()
    mouse1click()
    wait(0.03)
    mouse1click()
    wait(0.03)
    
    if settings.UseSkills then
        for _, key in ipairs({"1", "2", "3", "Z"}) do
            vInput:SendKeyEvent(true, key, false, game)
            wait(0.02)
            vInput:SendKeyEvent(false, key, false, game)
            wait(0.03)
        end
    end
end

-- ====== AUTO FARM ======

function autoFarm()
    print("🟢 Auto Farm STARTED")
    while state.farming do
        wait(0.1)
        if currentTarget == nil or not isAlive(currentTarget) then
            currentTarget = getNearestMob()
            if currentTarget then
                local pos = currentTarget.HumanoidRootPart.CFrame
                teleport(CFrame.new(pos.X, pos.Y + settings.FlyHeight, pos.Z))
                wait(0.1)
            end
        end
        if currentTarget and isAlive(currentTarget) then
            local mobPos = currentTarget.HumanoidRootPart.Position
            local dist = (rootPart.Position - mobPos).Magnitude
            if dist > 50 then
                local pos = currentTarget.HumanoidRootPart.CFrame
                teleport(CFrame.new(pos.X, pos.Y + settings.FlyHeight, pos.Z))
                wait(0.05)
            end
            for i = 1, 15 do
                if not state.farming then break end
                if not isAlive(currentTarget) then break end
                doAttack()
                wait(settings.AttackDelay)
            end
        else
            local mobs = getMobs()
            if #mobs > 0 then
                currentTarget = mobs[math.random(1, #mobs)]
                if isAlive(currentTarget) then
                    local pos = currentTarget.HumanoidRootPart.CFrame
                    teleport(CFrame.new(pos.X, pos.Y + settings.FlyHeight, pos.Z))
                    wait(0.2)
                end
            else
                wait(0.5)
            end
        end
    end
end

-- ====== AUTO COLLECT ======

function autoCollect()
    while state.collecting do
        wait(0.3)
        for _, fruit in pairs(getFruits()) do
            if fruit:FindFirstChild("Handle") then
                local dist = (rootPart.Position - fruit.Handle.Position).Magnitude
                if dist < settings.CollectRadius then
                    teleport(fruit.Handle.CFrame * CFrame.new(0, 0, 2))
                    wait(0.1)
                    fireclickdetector(fruit.Handle.ClickDetector)
                    wait(0.2)
                end
            end
        end
    end
end

-- ====== AUTO HAKI ======

function autoHaki()
    while state.haki do
        wait(2)
        if humanoid:FindFirstChild("Haki") then
            humanoid.Haki.Value = true
        end
        if humanoid:FindFirstChild("Ken") then
            humanoid.Ken.Value = true
        end
    end
end

-- ====== ESP ======

function esp()
    while state.esp do
        wait(0.5)
        for _, mob in pairs(getMobs()) do
            if isAlive(mob) and not mob:FindFirstChild("Highlight") then
                local hl = Instance.new("Highlight")
                hl.Parent = mob
                hl.FillColor = Color3.new(1, 0, 0)
                hl.FillTransparency = 0.4
            end
        end
        for _, fruit in pairs(getFruits()) do
            if fruit:FindFirstChild("Handle") and not fruit:FindFirstChild("Highlight") then
                local hl = Instance.new("Highlight")
                hl.Parent = fruit
                hl.FillColor = Color3.new(0, 1, 0)
                hl.FillTransparency = 0.3
            end
        end
    end
    for _, mob in pairs(getMobs()) do
        if mob:FindFirstChild("Highlight") then mob.Highlight:Destroy() end
    end
    for _, fruit in pairs(getFruits()) do
        if fruit:FindFirstChild("Highlight") then fruit.Highlight:Destroy() end
    end
end

-- ====== ANTI FALL ======

function antiFall()
    while state.antiFall do
        wait(0.1)
        if rootPart.Position.Y < -50 then
            teleport(CFrame.new(0, 100, 0))
        end
    end
end

