-- ====== SETTINGS TAB ======

function createSettingsTab()
    local settingsList = {
        {name = "Farm Radius", key = "FarmRadius", min = 100, max = 800, default = 400},
        {name = "Attack Delay", key = "AttackDelay", min = 0.03, max = 0.5, default = 0.08},
        {name = "Collect Radius", key = "CollectRadius", min = 50, max = 400, default = 200},
        {name = "Fly Height", key = "FlyHeight", min = 3, max = 20, default = 8},
    }
    
    for _, setting in pairs(settingsList) do
        local frame = Instance.new("Frame")
        frame.Size = UDim2.new(1, 0, 0, 35)
        frame.BackgroundTransparency = 1
        frame.Parent = scrollFrame
        
        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(0.5, 0, 1, 0)
        label.Text = setting.name
        label.TextColor3 = Color3.new(1, 1, 1)
        label.BackgroundTransparency = 1
        label.Font = Enum.Font.GothamMedium
        label.TextSize = 12
        label.TextXAlignment = Enum.TextXAlignment.Left
        label.Parent = frame
        
        local slider = Instance.new("TextBox")
        slider.Size = UDim2.new(0.3, 0, 0.7, 0)
        slider.Position = UDim2.new(0.6, 0, 0.15, 0)
        slider.Text = tostring(settings[setting.key])
        slider.BackgroundColor3 = Color3.new(0.15, 0.15, 0.2)
        slider.TextColor3 = Color3.new(1, 1, 1)
        slider.BorderSizePixel = 0
        slider.Font = Enum.Font.GothamMedium
        slider.TextSize = 12
        slider.Parent = frame
        slider:GetPropertyChangedSignal("Text"):Connect(function()
            local val = tonumber(slider.Text)
            if val then
                settings[setting.key] = val
            end
        end)
    end
    
    updateCanvas()
end

-- ====== HELPER FUNCTIONS ======

function createToggleButton2(text, color, toggleFunc, stateKey)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.9, 0, 0, 35)
    btn.Text = text
    btn.BackgroundColor3 = color
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.BorderSizePixel = 0
    btn.Font = Enum.Font.GothamMedium
    btn.TextSize = 13
    btn.Parent = scrollFrame
    
    btn.MouseButton1Click:Connect(function()
        toggleFunc()
        local active = state[stateKey]
        btn.BackgroundColor3 = active and Color3.new(0, 0.8, 0) or color
        btn.Text = active and "▶ " .. text or text
    end)
    return btn
end

function updateCanvas()
    local count = 0
    for _, child in pairs(scrollFrame:GetChildren()) do
        if child:IsA("TextButton") or child:IsA("TextLabel") or child:IsA("Frame") then
            count = count + 1
        end
    end
    scrollFrame.CanvasSize = UDim2.new(0, 0, 0, count * 40 + 20)
end

