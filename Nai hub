--[[ 
  BLOX FRUITS SCRIPT - FIXED VERSION
  Features: Auto Farm + Auto Collect + Mini GUI + Exit Button
--]]

repeat wait(0.1) until game:IsLoaded()

local player = game.Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")
local rootPart = character:WaitForChild("HumanoidRootPart")
local virtualInput = game:GetService("VirtualInputManager")
local runService = game:GetService("RunService")

-- ====== SETTINGS ======
local FARM_RADIUS = 300
local ATTACK_DELAY = 0.08
local COLLECT_RADIUS = 200
local TELEPORT_DISTANCE = 40
local USE_SKILLS = true

-- ====== VARIABLES ======
local isFarming = false
local isCollecting = false
local farmThread = nil
local collectThread = nil

-- ====== UTILITY ======
function teleport(pos)
    rootPart.CFrame = pos
    wait(0.05)
end

function isAlive(mob)
    return mob and mob:FindFirstChild("Humanoid") and mob.Humanoid.Health > 0
end

function getNearestMob()
    local nearest = nil
    local nearestDist = math.huge
    
    for _, mob in pairs(game:GetService("Workspace").Enemies:GetChildren()) do
        if isAlive(mob) then
            local dist = (rootPart.Position - mob.HumanoidRootPart.Position).Magnitude
            if dist < FARM_RADIUS and dist < nearestDist then
                nearestDist = dist
                nearest = mob
            end
        end
    end
    return nearest
end

function attack()
    virtualInput:SendMouseButtonEvent(0, 0, 0, true, game, 0)
    wait(0.03)
    virtualInput:SendMouseButtonEvent(0, 0, 0, false, game, 0)
    
    if USE_SKILLS then
        for _, key in ipairs({"1", "2", "3"}) do
            virtualInput:SendKeyEvent(true, key, false, game)
            wait(0.02)
            virtualInput:SendKeyEvent(false, key, false, game)
            wait(0.03)
        end
    end
end

-- ====== AUTO FARM ======
function autoFarmLevel()
    print("Auto Farm started!")
    while isFarming do
        wait(0.1)
        local mob = getNearestMob()
        
        if mob then
            local pos = mob.HumanoidRootPart.CFrame * CFrame.new(0, 0, TELEPORT_DISTANCE)
            teleport(pos)
            wait(0.05)
            
            for i = 1, 5 do
                attack()
                wait(ATTACK_DELAY)
            end
        else
            wait(0.5)
            -- Teleport to random mob if none found
            local enemies = game:GetService("Workspace").Enemies:GetChildren()
            if #enemies > 0 then
                local mob = enemies[math.random(1, #enemies)]
                if isAlive(mob) then
                    teleport(mob.HumanoidRootPart.CFrame * CFrame.new(0, 0, TELEPORT_DISTANCE))
                end
            end
        end
    end
end

-- ====== AUTO COLLECT ======
function autoCollectFruit()
    print("Auto Collect started!")
    while isCollecting do
        wait(0.3)
        
        for _, fruit in pairs(game:GetService("Workspace").Fruits:GetChildren()) do
            if fruit:FindFirstChild("Handle") then
                local dist = (rootPart.Position - fruit.Handle.Position).Magnitude
                if dist < COLLECT_RADIUS then
                    teleport(fruit.Handle.CFrame * CFrame.new(0, 0, 2))
                    wait(0.1)
                    fireclickdetector(fruit.Handle.ClickDetector)
                    wait(0.2)
                end
            end
        end
    end
end

-- ====== START/STOP ======
function toggleFarm()
    isFarming = not isFarming
    if isFarming then
        farmThread = spawn(autoFarmLevel)
    else
        if farmThread then
            coroutine.close(farmThread)
            farmThread = nil
        end
    end
end

function toggleCollect()
    isCollecting = not isCollecting
    if isCollecting then
        collectThread = spawn(autoCollectFruit)
    else
        if collectThread then
            coroutine.close(collectThread)
            collectThread = nil
        end
    end
end

-- ====== TELEPORT ======
function teleportToIsland(name)
    local islands = {
        Jungle = CFrame.new(-1174, 54, 288),
        ["Pirate Village"] = CFrame.new(-802, 55, 604),
        Desert = CFrame.new(-1068, 53, -1082),
        ["Ice Island"] = CFrame.new(586, 43, -2516),
        ["Marine Fortress"] = CFrame.new(2816, 9, -892),
        ["Sky Islands"] = CFrame.new(326, 192, 3208),
        ["Great Tree"] = CFrame.new(2444, 368, -6988),
        ["Kingdom of Rose"] = CFrame.new(-1036, 18, 12678),
        ["Castle on the Sea"] = CFrame.new(3931, 36, 13748),
    }
    if islands[name] then
        teleport(islands[name])
        print("Teleported to: " .. name)
    end
end

