-- Buttons
function createSmallButton(text, posY, color, callback)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.85, 0, 0, 28)
    btn.Position = UDim2.new(0.075, 0, posY, 0)
    btn.Text = text
    btn.BackgroundColor3 = color
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.GothamMedium
    btn.TextSize = 12
    btn.Parent = mainFrame
    
    local state = false
    btn.MouseButton1Click:Connect(function()
        state = not state
        if state then
            btn.BackgroundColor3 = Color3.new(0, 0.8, 0)
            btn.Text = "▶ " .. text
        else
            btn.BackgroundColor3 = color
            btn.Text = text
        end
        callback()
    end)
    return btn
end

createSmallButton("FARM", 0.15, Color3.new(0.2, 0.6, 0.2), toggleFarm)
