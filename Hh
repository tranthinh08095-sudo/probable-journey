-- Button creator
function createButton(text, posY, color, callback)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.85, 0, 0, 32)
    btn.Position = UDim2.new(0.075, 0, posY, 0)
    btn.Text = text
    btn.BackgroundColor3 = color
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.GothamMedium
    btn.TextSize = 13
    btn.Parent = mainFrame
    
    local isOn = false
    btn.MouseButton1Click:Connect(function()
        callback()
        if text:match("FARM") then isOn = state.farming
        elseif text:match("COLLECT") then isOn = state.collecting
        elseif text:match("HAKI") then isOn = state.haki
        elseif text:match("ESP") then isOn = state.esp
        end
        btn.BackgroundColor3 = isOn and Color3.new(0, 0.8, 0) or color
        btn.Text = isOn and "▶ " .. text or text
    end)
    return btn
end

