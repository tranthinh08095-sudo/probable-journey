-- --- AUTO EQUIP WEAPON ---
local function equip()
    pcall(function()
        for _, v in pairs(p.Backpack:GetChildren()) do
            if v:IsA("Tool") and v.ToolTip == getgenv().Config.Weapon then
                p.Character.Humanoid:EquipTool(v)
            end
        end
    end)
end

-- --- AUTOMATIC QUEST AND MOB DETECTOR ---
local function getQuestData()
    local lvl = p.Data.Level.Value
    if game.PlaceId == 2753915549 then -- Sea 1
        if lvl >= 1925 then return "IceCreamZombieQuest", "Ice Cream Zombie", 1
        elseif lvl >= 1200 then return "LavaPirateQuest", "Lava Pirate", 1
        else return "BanditQuest1", "Bandit", 1 end
    elseif game.PlaceId == 4442272163 then -- Sea 2
        if lvl >= 1200 and lvl < 1250 then return "LavaPirateQuest", "Lava Pirate", 1
        else return "Area1Quest", "Raider", 1 end
    else -- Sea 3
        if lvl >= 1925 and lvl < 1975 then return "IceCreamZombieQuest", "Ice Cream Zombie", 1
        else return "PiratePortQuest", "Pirate Millionaire", 1 end
    end
end

-- --- BACKEND LOOPS ---

-- 1. Auto Farm Level Loop
task.spawn(function()
    while task.wait(0.1) do
        if getgenv().Config.AutoFarm and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            pcall(function()
                local qName, mName, qId = getQuestData()
                if not p.PlayerGui.Main.Quest.Visible then 
                    rem:InvokeServer("StartQuest", qName, qId) 
                end
                for _, e in pairs(game:GetService("Workspace").Enemies:GetChildren()) do
                    if e.Name == mName and e:FindFirstChild("HumanoidRootPart") and e.Humanoid.Health > 0 then
                        equip()
                        p.Character.HumanoidRootPart.CFrame = e.HumanoidRootPart.CFrame * CFrame.new(0, 5, 0)
                        rem:InvokeServer("AttackStart")
                    end
                end
            end)
        end
    end
end)

-- 2. Bring Mob Loop
task.spawn(function()
    while task.wait(0.1) do
        if getgenv().Config.BringMob and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            pcall(function()
                local _, mName, _ = getQuestData()
                for _, v in pairs(game:GetService("Workspace").Enemies:GetChildren()) do
                    if v.Name == mName and v:FindFirstChild("HumanoidRootPart") and v.Humanoid.Health > 0 then
                        if (v.HumanoidRootPart.Position - p.Character.HumanoidRootPart.Position).Magnitude <= 350 then
                            v.HumanoidRootPart.CFrame = p.Character.HumanoidRootPart.CFrame * CFrame.new(0, -5, 0)
                            v.HumanoidRootPart.CanCollide = false
                        end
                    end
                end
            end)
        end
    end
end)

