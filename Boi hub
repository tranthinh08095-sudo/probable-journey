-- Boy Hub | Optimized Version
local Fluent = loadstring(game:HttpGet("https://github.com/dawid-scripts/Fluent/releases/latest/download/main.lua"))()

local Window = Fluent:CreateWindow({
    Title = "BOY HUB | PRO",
    SubTitle = "v1.2 - Stable",
    TabWidth = 160,
    Size = UDim2.fromOffset(550, 400),
    Theme = "Dark",
    MinimizeKey = Enum.KeyCode.LeftControl
})

-- Anti-AFK Service
local VirtualUser = game:GetService("VirtualUser")
game:GetService("Players").LocalPlayer.Idled:Connect(function()
    VirtualUser:Button2Down(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
    task.wait(1)
    VirtualUser:Button2Up(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
end)

-- Configuration
getgenv().Config = { AutoFarm = false, BringMob = false, AutoSkill = true }
local Player = game:GetService("Players").LocalPlayer
local Remotes = game:GetService("ReplicatedStorage").Remotes.CommF_

-- Interface Setup
local FarmTab = Window:AddTab({ Title = "Farm", Icon = "rbxassetid://4483345906" })
FarmTab:AddToggle("AF", {Title = "Auto Farm Level", Default = false}):OnChanged(function(v) getgenv().Config.AutoFarm = v end)
FarmTab:AddToggle("BM", {Title = "Bring Mob", Default = false}):OnChanged(function(v) getgenv().Config.BringMob = v end)
FarmTab:AddToggle("AS", {Title = "Auto Skill (Z,X,C)", Default = true}):OnChanged(function(v) getgenv().Config.AutoSkill = v end)

-- Quest Logic
local function getQuest()
    local Level = Player.Data.Level.Value
    if Level >= 1 and Level < 10 then return "BanditQuest1", "Bandit", 1
    elseif Level >= 10 and Level < 30 then return "MonkeyQuest", "Monkey", 1
    elseif Level >= 30 and Level < 60 then return "GorillaQuest", "Gorilla", 1
    else return "BanditQuest1", "Bandit", 1 end
end

-- Core Farming Loop
task.spawn(function()
    while task.wait(0.1) do
        if getgenv().Config.AutoFarm then
            pcall(function()
                local QuestName, MobName, QuestId = getQuest()
                local Character = Player.Character
                if not Character or not Character:FindFirstChild("HumanoidRootPart") then return end
                
                -- Ensure Quest is active
                if not Player.PlayerGui.Main.Quest.Visible then 
                    Remotes:InvokeServer("StartQuest", QuestName, QuestId) 
                end
                
                -- Find nearest target
                local Target = nil
                local ShortestDistance = 9999
                
                for _, Enemy in pairs(workspace.Enemies:GetChildren()) do
                    if Enemy.Name == MobName and Enemy:FindFirstChild("HumanoidRootPart") and Enemy.Humanoid.Health > 0 then
                        local Distance = (Enemy.HumanoidRootPart.Position - Character.HumanoidRootPart.Position).Magnitude
                        if Distance < ShortestDistance then
                            ShortestDistance = Distance
                            Target = Enemy
                        end
                    end
                end

                -- Combat Logic
                if Target then
                    local HRP = Target.HumanoidRootPart
                    
                    -- Bring Mob to position
                    if getgenv().Config.BringMob then
                        HRP.CFrame = Character.HumanoidRootPart.CFrame * CFrame.new(0, -3, 0)
                    end
                    
                    -- Teleport to stand on top of the target
                    Character.HumanoidRootPart.CFrame = HRP.CFrame * CFrame.new(0, 3, 0)
                    
                    -- Trigger attack
                    Remotes:InvokeServer("AttackStart")
                    
                    -- Trigger skills if enabled
                    if getgenv().Config.AutoSkill then
                        for _, Key in pairs({"Z", "X", "C"}) do
                            game:GetService("VirtualInputManager"):SendKeyEvent(true, Key, false, game)
                        end
                    end
                end
            end)
        end
    end
end)
