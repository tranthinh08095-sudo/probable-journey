-- Tabs
local FarmTab = Window:AddTab({ Title = "Farm", Icon = "rbxassetid://4483345906" })
FarmTab:AddToggle("AF", {Title = "Auto Farm Level", Default = false}):OnChanged(function(v) getgenv().Config.AutoFarm = v end)
FarmTab:AddToggle("BM", {Title = "Bring Mob", Default = false}):OnChanged(function(v) getgenv().Config.BringMob = v end)

-- Logic: Quest Detector
local function getQuest()
    local lvl = p.Data.Level.Value
    if lvl >= 1 and lvl < 10 then return "BanditQuest1", "Bandit", 1
    elseif lvl >= 10 and lvl < 30 then return "MonkeyQuest", "Monkey", 1
    elseif lvl >= 30 and lvl < 60 then return "GorillaQuest", "Gorilla", 1
    else return "BanditQuest1", "Bandit", 1 end
end

-- Auto Farm Loop
task.spawn(function()
    while task.wait(0.2) do
        if getgenv().Config.AutoFarm then
            pcall(function()
                local qName, mName, qId = getQuest()
                if not p.PlayerGui.Main.Quest.Visible then 
                    rem:InvokeServer("StartQuest", qName, qId) 
                end
                for _, e in pairs(game:GetService("Workspace").Enemies:GetChildren()) do
                    if e.Name == mName and e:FindFirstChild("HumanoidRootPart") then
                        p.Character.HumanoidRootPart.CFrame = e.HumanoidRootPart.CFrame * CFrame.new(0, 5, 0)
                        rem:InvokeServer("AttackStart")
                    end
                end
            end)
        end
    end
end)

-- Bring Mob Loop
task.spawn(function()
    while task.wait(0.2) do
        if getgenv().Config.BringMob then
            pcall(function()
                local _, mName, _ = getQuest()
                for _, e in pairs(game:GetService("Workspace").Enemies:GetChildren()) do
                    if e.Name == mName and e:FindFirstChild("HumanoidRootPart") then
                        e.HumanoidRootPart.CFrame = p.Character.HumanoidRootPart.CFrame
                    end
                end
            end)
        end
    end
end)
