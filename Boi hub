    Title = "BANANA CAT HUB : Blox Fruits",
    SubTitle = "by Boy",
    TabWidth = 160,
    Size = UDim2.fromOffset(550, 320),
    Theme = "Dark"
})

-- Tạo đầy đủ các Tab bên trái y hệt như trong ảnh mày gửi
local Tabs = {
    Farm = Window:AddTab({ Title = "Farm", Icon = "rbxassetid://4483345906" }),
    Config = Window:AddTab({ Title = "Config", Icon = "rbxassetid://4483345906" }),
    Fighting = Window:AddTab({ Title = "Fighting Style", Icon = "rbxassetid://4483345906" }),
    Items = Window:AddTab({ Title = "Items Farm", Icon = "rbxassetid://4483345906" }),
    SeaEvents = Window:AddTab({ Title = "Sea Events", Icon = "rbxassetid://4483345906" }),
    Mirage = Window:AddTab({ Title = "Mirage + RaceV4", Icon = "rbxassetid://4483345906" }),
    Drago = Window:AddTab({ Title = "Drago Dojo", Icon = "rbxassetid://4483345906" }),
    Prehistoric = Window:AddTab({ Title = "Prehistoric", Icon = "rbxassetid://4483345906" }),
    TapKich = Window:AddTab({ Title = "Tập kích", Icon = "rbxassetid://4483345906" })
}

getgenv().Config = { AutoFarm = false, BringMob = false, Weapon = "Melee" }
local p = game.Players.LocalPlayer
local rem = game:GetService("ReplicatedStorage").Remotes.CommF_

-- --- TAB FARM ---
local ToggleFarm = Tabs.Farm:AddToggle("AutoFarm", {Title = "Auto Farm Level", Default = false})
ToggleFarm:OnChanged(function() getgenv().Config.AutoFarm = ToggleFarm.Value end)

local ToggleGom = Tabs.Farm:AddToggle("BringMob", {Title = "Bring Mob (Ground)", Default = false})
ToggleGom:OnChanged(function() getgenv().Config.BringMob = ToggleGom.Value end)

-- Các nút chức năng phụ mô phỏng theo ảnh mẫu
Tabs.Farm:AddToggle("AutoBartic", {Title = "Auto Done Bartilo Quest", Default = false})
Tabs.Farm:AddToggle("AutoCitizen", {Title = "Auto Done Citizen Quest", Default = false})
Tabs.Farm:AddToggle("AutoDummy", {Title = "Auto Training Dummy", Default = false})
Tabs.Farm:AddToggle("AutoChest", {Title = "Auto Collect Chest", Default = false})

-- --- TAB CONFIG ---
local DropdownWeapon = Tabs.Config:AddDropdown("WeaponSelect", {
    Title = "Select Weapon",
    Values = {"Melee", "Sword", "Gun"},
    CurrentValue = "Melee"
})
DropdownWeapon:OnChanged(function(val) getgenv().Config.Weapon = val end)

-- --- LOGIC CORE ---
local function equip()
    pcall(function()
        for _, v in pairs(p.Backpack:GetChildren()) do
            if v:IsA("Tool") and v.ToolTip == getgenv().Config.Weapon then
                p.Character.Humanoid:EquipTool(v)
            end
        end
    end)
end

task.spawn(function()
    while task.wait(0.1) do
        if getgenv().Config.AutoFarm and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            pcall(function()
                if not p.PlayerGui.Main.Quest.Visible then 
                    rem:InvokeServer("StartQuest", "IceCreamZombieQuest", 1) 
                end
                for _, e in pairs(game:GetService("Workspace").Enemies:GetChildren()) do
                    if e.Name == "Ice Cream Zombie" and e:FindFirstChild("HumanoidRootPart") and e.Humanoid.Health > 0 then
                        equip()
                        p.Character.HumanoidRootPart.CFrame = e.HumanoidRootPart.CFrame * CFrame.new(0, 5, 0)
                        rem:InvokeServer("AttackStart")
                    end
                end
            end)
        end
    end
end)

task.spawn(function()
    while task.wait(0.1) do
        if getgenv().Config.BringMob and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            pcall(function()
                for _, v in pairs(game:GetService("Workspace").Enemies:GetChildren()) do
                    if v:FindFirstChild("HumanoidRootPart") and v.Humanoid.Health > 0 then
                        if (v.HumanoidRootPart.Position - p.Character.HumanoidRootPart.Position).Magnitude <= 350 then
                            v.HumanoidRootPart.CFrame = p.Character.HumanoidRootPart.CFrame * CFrame.new(0, -5, 0)
                            v.HumanoidRootPart.CanCollide = false
                        end
                    end
                end
            end)
        end
    end
end)

Fluent:Notify({ Title = "BOY HUB", Content = "Script loaded successfully!", Duration = 5 })
