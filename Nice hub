local starterGear = game:GetService("StarterGear")

-- ====== SETTINGS ======
local FARM_RADIUS = 500
local ATTACK_DELAY = 0.08
local COLLECT_RADIUS = 200
local USE_SKILLS = true
local FLY_HEIGHT = 8

-- ====== WEAPON SETTINGS ======
local selectedWeaponType = "Melee" -- Mặc định là Melee (có thể đổi thành "Sword" hoặc "Gun")
local weaponSlot = 1 -- Slot vũ khí: 1 = Melee, 2 = Sword, 3 = Gun

-- Danh sách vũ khí (để hiển thị GUI)
local weaponList = {
    ["Melee"] = {slot = 1, key = "1"},
    ["Sword"] = {slot = 2, key = "2"},
    ["Gun"] = {slot = 3, key = "3"},
}

-- ====== VARIABLES CONTROL ======
local isFarming = false
local isCollecting = false
local farmThread = nil
local collectThread = nil
local currentTarget = nil
local currentWeapon = "Melee"

-- ====== UTILITY FUNCTIONS ======

function teleport(pos)
    rootPart.CFrame = pos
    wait(0.05)
end

function teleportOnHead(mob)
    if mob and mob:FindFirstChild("HumanoidRootPart") then
        local pos = mob.HumanoidRootPart.CFrame
        local headPos = CFrame.new(pos.X, pos.Y + FLY_HEIGHT, pos.Z)
        rootPart.CFrame = headPos
        wait(0.05)
        return true
    end
    return false
end

function isAlive(mob)
    return mob and mob:FindFirstChild("Humanoid") and mob.Humanoid.Health > 0
end

function getNearestMob()
    local nearest = nil
    local nearestDist = math.huge
    local enemies = game:GetService("Workspace").Enemies
    
    for _, mob in pairs(enemies:GetChildren()) do
        if isAlive(mob) then
            local dist = (rootPart.Position - mob.HumanoidRootPart.Position).Magnitude
            if dist < FARM_RADIUS and dist < nearestDist then
                nearestDist = dist
                nearest = mob
            end
        end
    end
    return nearest
end

-- ====== WEAPON FUNCTIONS ======

function equipWeapon(weaponType)
    -- Lấy vũ khí trong kho đồ
    local backpack = player:FindFirstChild("Backpack")
    if not backpack then return end
    
    local weaponFound = false
    local weaponName = ""
    
    -- Tìm vũ khí theo loại
    for _, item in pairs(backpack:GetChildren()) do
        if item:IsA("Tool") then
            local itemName = item.Name:lower()
            
            if weaponType == "Melee" then
                -- Kiểm tra nếu là Melee (không có "Sword" hoặc "Gun" trong tên)
                if not itemName:find("sword") and not itemName:find("gun") and not itemName:find("pistol") and not itemName:find("rifle") then
                    weaponFound = true
                    weaponName = item.Name
                    break
                end
            elseif weaponType == "Sword" then
                if itemName:find("sword") or itemName:find("blade") or itemName:find("katana") or itemName:find("cutlass") then
                    weaponFound = true
                    weaponName = item.Name
                    break
                end
            elseif weaponType == "Gun" then
                if itemName:find("gun") or itemName:find("pistol") or itemName:find("rifle") or itemName:find("cannon") then
                    weaponFound = true
                    weaponName = item.Name
                    break
                end
            end
        end
    end
    
    -- Nếu tìm thấy, trang bị vũ khí
    if weaponFound and weaponName ~= "" then
        character:FindFirstChild(weaponName) or player.Backpack:FindFirstChild(weaponName):Parent(character)
        print("✅ Equipped: " .. weaponName)
        
        -- Bấm phím tương ứng để đổi vũ khí
        local slotKey = weaponList[weaponType].key
        virtualInput:SendKeyEvent(true, slotKey, false, game)
        wait(0.05)
        virtualInput:SendKeyEvent(false, slotKey, false, game)
        wait(0.1)
        
        return true
    else
        print("❌ No " .. weaponType .. " found! Using default weapon.")
        return false
    end
end

function useWeapon()
    -- Sử dụng vũ khí hiện tại
    if currentWeapon == "Melee" then
        -- Đánh tay không
        virtualInput:SendMouseButtonEvent(0, 0, 0, true, game, 0)
        wait(0.03)
        virtualInput:SendMouseButtonEvent(0, 0, 0, false, game, 0)
    elseif currentWeapon == "Sword" then
        -- Sử dụng kiếm (click + skill)
        virtualInput:SendMouseButtonEvent(0, 0, 0, true, game, 0)
        wait(0.03)
        virtualInput:SendMouseButtonEvent(0, 0, 0, false, game, 0)
        wait(0.05)
        -- Dùng skill kiếm (phím Z)
        virtualInput:SendKeyEvent(true, "Z", false, game)
        wait(0.02)
        virtualInput:SendKeyEvent(false, "Z", false, game)
    elseif currentWeapon == "Gun" then
        -- Sử dụng súng (click + skill)
        virtualInput:SendMouseButtonEvent(0, 0, 0, true, game, 0)
        wait(0.03)
        virtualInput:SendMouseButtonEvent(0, 0, 0, false, game, 0)
        wait(0.05)
        -- Dùng skill súng (phím Z)
        virtualInput:SendKeyEvent(true, "Z", false, game)
        wait(0.02)
        virtualInput:SendKeyEvent(false, "Z", false, game)
    end
end

function attack()
    useWeapon()
    
    if USE_SKILLS then
        for _, key in ipairs({"1", "2", "3"}) do
            virtualInput:SendKeyEvent(true, key, false, game)
            wait(0.02)
            virtualInput:SendKeyEvent(false, key, false, game)
            wait(0.03)
        end
    end
end

-- ====== AUTO FARM LEVEL ======

function autoFarmLevel()
    print("Auto Farm Level started!")
    currentTarget = nil
    
    -- Trang bị vũ khí ban đầu
    equipWeapon(currentWeapon)
    
    while isFarming do
        wait(0.1)
        
        if currentTarget == nil or not isAlive(currentTarget) then
            currentTarget = getNearestMob()
            if currentTarget then
                teleportOnHead(currentTarget)
                wait(0.1)
            end
        end
        
        if currentTarget and isAlive(currentTarget) then
            local mobPos = currentTarget.HumanoidRootPart.Position
            local dist = (rootPart.Position - mobPos).Magnitude
            local heightDiff = rootPart.Position.Y - mobPos.Y
            
            if dist > 40 or heightDiff < 3 then
                teleportOnHead(currentTarget)
                wait(0.05)
            end
            
            for i = 1, 12 do
                if not isFarming then break end
                if not isAlive(currentTarget) then break end
                
                attack()
                wait(ATTACK_DELAY)
                
                if i % 5 == 0 then
                    local newDist = (rootPart.Position - currentTarget.HumanoidRootPart.Position).Magnitude
                    if newDist > 50 then
                        break
                    end
                end
            end
        else
            local enemies = game:GetService("Workspace").Enemies:GetChildren()
            if #enemies > 0 then
                currentTarget = enemies[math.random(1, #enemies)]
                if isAlive(currentTarget) then
                    teleportOnHead(currentTarget)
                    wait(0.2)
                end
            else
                wait(0.5)
            end
        end
    end
end

-- ====== AUTO COLLECT FRUIT ======

function autoCollectFruit()
    print("Auto Collect Fruit started!")
    
    while isCollecting do
        wait(0.3)
        
        for _, fruit in pairs(game:GetService("Workspace").Fruits:GetChildren()) do
            if fruit:FindFirstChild("Handle") then
                local dist = (rootPart.Position - fruit.Handle.Position).Magnitude
                if dist < COLLECT_RADIUS then
                    teleport(fruit.Handle.CFrame * CFrame.new(0, 0, 2))
                    wait(0.1)
                    fireclickdetector(fruit.Handle.ClickDetector)
                    wait(0.2)
                end
            end
        end
    end
end

-- ====== TOGGLE FUNCTIONS ======

function toggleFarm()
    isFarming = not isFarming
    if isFarming then
        if farmThread then coroutine.close(farmThread) end
        farmThread = spawn(autoFarmLevel)
        print("✅ Farm ON - Using " .. currentWeapon)
    else
        if farmThread then
            coroutine.close(farmThread)
            farmThread = nil
        end
        currentTarget = nil
        print("❌ Farm OFF")
    end
end

function toggleCollect()
    isCollecting = not isCollecting
    if isCollecting then
        if collectThread then coroutine.close(collectThread) end
        collectThread = spawn(autoCollectFruit)
        print("✅ Collect ON")
    else
        if collectThread then
            coroutine.close(collectThread)
            collectThread = nil
        end
        print("❌ Collect OFF")
    end
end

function setWeapon(weaponType)
    if weaponType == currentWeapon then
        print("ℹ️ Already using " .. weaponType)
        return
    end
    
    currentWeapon = weaponType
    if isFarming then
        equipWeapon(weaponType)
        print("✅ Switched to: " .. weaponType)
    else
        print("ℹ️ Weapon set to: " .. weaponType .. " (will equip when farming starts)")
    end
end

