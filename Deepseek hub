--[[ 
  BLOX FRUITS SCRIPT - AUTO FARM + COLLECT
  Fixed: Stand on top of mob, no teleport loop
--]]

repeat wait(0.1) until game:IsLoaded()

-- ====== VARIABLES ======
local player = game.Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")
local rootPart = character:WaitForChild("HumanoidRootPart")
local virtualInput = game:GetService("VirtualInputManager")

-- ====== SETTINGS ======
local FARM_RADIUS = 500
local ATTACK_DELAY = 0.08
local COLLECT_RADIUS = 200
local USE_SKILLS = true

-- ====== VARIABLES CONTROL ======
local isFarming = false
local isCollecting = false
local farmThread = nil
local collectThread = nil
local currentTarget = nil
local targetPosition = nil

-- ====== UTILITY FUNCTIONS ======

function teleport(pos)
    rootPart.CFrame = pos
    wait(0.05)
end

function isAlive(mob)
    return mob and mob:FindFirstChild("Humanoid") and mob.Humanoid.Health > 0
end

function getNearestMob()
    local nearest = nil
    local nearestDist = math.huge
    local enemies = game:GetService("Workspace").Enemies
    
    for _, mob in pairs(enemies:GetChildren()) do
        if isAlive(mob) then
            local dist = (rootPart.Position - mob.HumanoidRootPart.Position).Magnitude
            if dist < FARM_RADIUS and dist < nearestDist then
                nearestDist = dist
                nearest = mob
            end
        end
    end
    return nearest
end

function attack()
    virtualInput:SendMouseButtonEvent(0, 0, 0, true, game, 0)
    wait(0.03)
    virtualInput:SendMouseButtonEvent(0, 0, 0, false, game, 0)
    
    if USE_SKILLS then
        for _, key in ipairs({"1", "2", "3"}) do
            virtualInput:SendKeyEvent(true, key, false, game)
            wait(0.02)
            virtualInput:SendKeyEvent(false, key, false, game)
            wait(0.03)
        end
    end
end

-- ====== AUTO FARM LEVEL (Đứng trên đầu quái) ======

function autoFarmLevel()
    print("Auto Farm Level started!")
    currentTarget = nil
    
    while isFarming do
        wait(0.1)
        
        -- Tìm quái mới nếu target chết hoặc mất
        if currentTarget == nil or not isAlive(currentTarget) then
            currentTarget = getNearestMob()
            if currentTarget then
                -- Đứng TRÊN ĐẦU quái (Y + 5 để đứng trên cao)
                local pos = currentTarget.HumanoidRootPart.CFrame
                targetPosition = CFrame.new(pos.X, pos.Y + 5, pos.Z)
                teleport(targetPosition)
                wait(0.1)
            end
        end
        
        if currentTarget and isAlive(currentTarget) then
            local mobPos = currentTarget.HumanoidRootPart.Position
            local dist = (rootPart.Position - mobPos).Magnitude
            
            -- Nếu quái bị đẩy ra xa hoặc mình bị rơi xuống
            if dist > 40 or rootPart.Position.Y < mobPos.Y then
                -- Teleport lại lên đầu quái
                local pos = currentTarget.HumanoidRootPart.CFrame
                targetPosition = CFrame.new(pos.X, pos.Y + 5, pos.Z)
                teleport(targetPosition)
                wait(0.05)
            end
            
            -- Đánh liên tục, không teleport lại nữa
            for i = 1, 12 do
                if not isFarming then break end
                if not isAlive(currentTarget) then break end
                
                attack()
                wait(ATTACK_DELAY)
                
                -- Chỉ kiểm tra mỗi 5 lần đánh
                if i % 5 == 0 then
                    local newDist = (rootPart.Position - currentTarget.HumanoidRootPart.Position).Magnitude
                    if newDist > 50 then
                        break -- Thoát vòng lặp để teleport lại
                    end
                end
            end
        else
            -- Không có quái, tìm quái khác
            local enemies = game:GetService("Workspace").Enemies:GetChildren()
            if #enemies > 0 then
                currentTarget = enemies[math.random(1, #enemies)]
                if isAlive(currentTarget) then
                    local pos = currentTarget.HumanoidRootPart.CFrame
                    targetPosition = CFrame.new(pos.X, pos.Y + 5, pos.Z)
                    teleport(targetPosition)
                    wait(0.2)
                end
            else
                wait(0.5)
            end
        end
    end
end

-- ====== AUTO COLLECT FRUIT ======

function autoCollectFruit()
    print("Auto Collect Fruit started!")
    
    while isCollecting do
        wait(0.3)
        
        for _, fruit in pairs(game:GetService("Workspace").Fruits:GetChildren()) do
            if fruit:FindFirstChild("Handle") then
                local dist = (rootPart.Position - fruit.Handle.Position).Magnitude
                if dist < COLLECT_RADIUS then
                    teleport(fruit.Handle.CFrame * CFrame.new(0, 0, 2))
                    wait(0.1)
                    fireclickdetector(fruit.Handle.ClickDetector)
                    wait(0.2)
                end
            end
        end
    end
end

-- ====== TOGGLE FUNCTIONS ======

function toggleFarm()
    isFarming = not isFarming
    if isFarming then
        if farmThread then coroutine.close(farmThread) end
        farmThread = spawn(autoFarmLevel)
        print("✅ Farm ON - Standing on mob head")
    else
        if farmThread then
            coroutine.close(farmThread)
            farmThread = nil
        end
        currentTarget = nil
        print("❌ Farm OFF")
    end
end

function toggleCollect()
    isCollecting = not isCollecting
    if isCollecting then
        if collectThread then coroutine.close(collectThread) end
        collectThread = spawn(autoCollectFruit)
        print("✅ Collect ON")
    else
        if collectThread then
            coroutine.close(collectThread)
            collectThread = nil
        end
        print("❌ Collect OFF")
    end
end

