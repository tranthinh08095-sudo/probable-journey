function createButton(text, posY, color, callback)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.85, 0, 0, 30)
    btn.Position = UDim2.new(0.075, 0, posY, 0)
    btn.Text = text
    btn.BackgroundColor3 = color
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.GothamMedium
    btn.TextSize = 12
    btn.Parent = mainFrame
    
    btn.MouseButton1Click:Connect(function()
        callback()
        if text == "FARM" then
            btn.BackgroundColor3 = isFarming and Color3.new(0, 0.8, 0) or Color3.new(0.2, 0.6, 0.2)
            btn.Text = isFarming and "▶ FARM" or "FARM"
        elseif text == "COLLECT" then
            btn.BackgroundColor3 = isCollecting and Color3.new(0, 0.8, 0) or Color3.new(0.6, 0.4, 0.1)
            btn.Text = isCollecting and "▶ COLLECT" or "COLLECT"
        end
    end)
    return btn
end

