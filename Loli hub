-- ====== VARIABLES ======
local player = game.Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")
local rootPart = character:WaitForChild("HumanoidRootPart")
local virtualInput = game:GetService("VirtualInputManager")

-- ====== SETTINGS ======
local FARM_RADIUS = 300
local ATTACK_DELAY = 0.08
local COLLECT_RADIUS = 200
local TELEPORT_DISTANCE = 40
local USE_SKILLS = true

-- ====== UTILITY FUNCTIONS ======

function teleport(pos)
    rootPart.CFrame = pos
    wait(0.05)
end

function isAlive(mob)
    return mob and mob:FindFirstChild("Humanoid") and mob.Humanoid.Health > 0
end

function getNearestMob()
    local nearest = nil
    local nearestDist = math.huge
    local enemies = game:GetService("Workspace").Enemies

    for _, mob in pairs(enemies:GetChildren()) do
        if isAlive(mob) then
            local dist = (rootPart.Position - mob.HumanoidRootPart.Position).Magnitude
            if dist < FARM_RADIUS and dist < nearestDist then
                nearestDist = dist
                nearest = mob
            end
        end
    end
    return nearest
end

function getMobsByLevel(minLevel, maxLevel)
    local mobs = {}
    for _, mob in pairs(game:GetService("Workspace").Enemies:GetChildren()) do
        if isAlive(mob) then
            local level = mob:FindFirstChild("Level") and mob.Level.Value or 0
            if level >= minLevel and level <= maxLevel then
                table.insert(mobs, mob)
            end
        end
    end
    return mobs
end

function attack()
    virtualInput:SendMouseButtonEvent(0, 0, 0, true, game, 0)
    wait(0.03)
    virtualInput:SendMouseButtonEvent(0, 0, 0, false, game, 0)
    
    if USE_SKILLS then
        for _, key in ipairs({"1", "2", "3"}) do
            virtualInput:SendKeyEvent(true, key, false, game)
            wait(0.02)
            virtualInput:SendKeyEvent(false, key, false, game)
            wait(0.03)
        end
    end
end

-- ====== AUTO FARM LEVEL ======

function autoFarmLevel()
    print("Auto Farm Level started!")
    local targetLevel = player:FindFirstChild("Data") and player.Data:FindFirstChild("Level")

    while true do
        wait(0.1)
        local mob = getNearestMob()

        if mob then
            local pos = mob.HumanoidRootPart.CFrame * CFrame.new(0, 0, TELEPORT_DISTANCE)
            teleport(pos)
            wait(0.05)
            
            for i = 1, 5 do
                attack()
                wait(ATTACK_DELAY)
            end

            if targetLevel then
                local currentLevel = targetLevel.Value
                local mobLevel = mob:FindFirstChild("Level") and mob.Level.Value or 0
            end
        else
            local mobs = getMobsByLevel(0, 1000)
            if #mobs > 0 then
                local mob = mobs[math.random(1, #mobs)]
                teleport(mob.HumanoidRootPart.CFrame * CFrame.new(0, 0, TELEPORT_DISTANCE))
                wait(0.2)
            end
        end
    end
end

-- ====== AUTO COLLECT FRUIT ======

function autoCollectFruit()
    print("Auto Collect Fruit started!")

    while true do
        wait(0.3)

        for _, fruit in pairs(game:GetService("Workspace").Fruits:GetChildren()) do
            if fruit:FindFirstChild("Handle") then
                local dist = (rootPart.Position - fruit.Handle.Position).Magnitude
                if dist < COLLECT_RADIUS then
                    teleport(fruit.Handle.CFrame * CFrame.new(0, 0, 2))
                    wait(0.1)
                    fireclickdetector(fruit.Handle.ClickDetector)
                    wait(0.2)
                end
            end
        end
    end
end

-- ====== AUTO FARM + COLLECT COMBO ======

function autoFarmAndCollect()
    print("Running Auto Farm + Auto Collect together!")

    spawn(autoFarmLevel)
    spawn(autoCollectFruit)

    while true do
        wait(60)
        local lvl = player.Data and player.Data.Level and player.Data.Level.Value or 0
        print("Farmed level: " .. lvl)
    end
end

